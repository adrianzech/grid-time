# Nuxt runtime mode
NODE_ENV=production

# Browser requests are served by Nuxt's schedule proxy
NUXT_PUBLIC_API_BASE=/_schedule

# Symfony's internal origin. The schedule proxy appends /api automatically
NUXT_INTERNAL_API_BASE=http://backend:8000

# Generate with: php bin/console api-key:create "Frontend" --internal
NUXT_FRONTEND_API_KEY=
